# Supabase — server only.
# These are never prefixed with NEXT_PUBLIC_, so they cannot reach the browser bundle.
# The client talks to /api/orders; only the server talks to Supabase.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# WhatsApp Business — the studio's number, in E.164 without the +.
# Server only: the message and the number are assembled on the server from the
# stored order, and the client receives a finished link. Not a secret, but not
# hardcoded either: the number changes, the code should not.

WHATSAPP_BUSINESS_NUMBER=966546040520

# Analytics — public by necessity (they end up in the browser either way).
# Leave both empty and nothing loads: no script, no beacon, no cookie.
# Set GTM *or* GA4; GTM wins if both are present.

NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=

# Prints every event to the console instead of sending it anywhere. Never in production.
NEXT_PUBLIC_ANALYTICS_DEBUG=

# Monitoring — Sentry. Leave empty and nothing is captured, loaded, or sent.
# The DSN is public by design (it can only write, never read).

NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Prints every captured event to the console instead of sending it. Never in production.
NEXT_PUBLIC_MONITORING_DEBUG=

# Set automatically on Vercel from the commit sha; override only if you need to.
NEXT_PUBLIC_RELEASE=
